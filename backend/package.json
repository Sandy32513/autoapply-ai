    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsdom": "^29.0.2",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.0",
