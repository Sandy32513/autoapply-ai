# ─── Server ───────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Supabase ─────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── CORS ─────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ─── OCR Settings ───────────────────────────────
# Set to false to disable OCR for scanned PDFs (faster parsing)
ENABLE_OCR=true

# ─── Queue Settings ─────────────────────────────
# Set to true in production to use Redis (recommended)
USE_REDIS=false
REDIS_URL=redis://localhost:6379
